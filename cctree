#!/usr/bin/env python3
"""
cctree — visualize Claude Code /branch trees.

Usage:
  cctree                      # trees for sessions whose cwd matches $PWD
  cctree --all                # trees across every project dir
  cctree --path <dir>         # trees for a specific working dir
  cctree --all-sessions       # include unbranched (leaf-only) sessions too
  cctree --watch              # tmux-aware sidebar: follow the active pane
  cctree --highlight <sid>    # render once, bold the given sessionId

Branch info comes from `forkedFrom` pointers in ~/.claude/projects/*/*.jsonl.
Active-session detection reads ~/.claude/sessions/<pid>.json and walks
descendants of the focused tmux pane.
"""
import argparse
import collections
import glob
import json
import os
import subprocess
import sys
import time
from datetime import datetime

__version__ = "0.2.0"


def extract_text(content):
    if isinstance(content, str):
        return content
    if isinstance(content, list):
        for b in content:
            if isinstance(b, dict) and b.get("type") == "text":
                return b.get("text", "")
    return ""


def is_preamble(text: str) -> bool:
    t = text.lstrip()
    if not t:
        return True
    preambles = (
        "<local-command-caveat>",
        "<command-name>",
        "<command-message>",
        "<command-stdout>",
        "<command-args>",
        "<local-command-stdout>",
        "You maintain a persistent memory system",
        "Caveat: The messages below",
    )
    return any(t.startswith(p) for p in preambles)


def scan_session(path):
    """Return dict of { sessionId, cwd, forkedFrom, title, first, mtime } or None."""
    sid = os.path.basename(path)[:-6]
    parent = parent_msg = cwd = first = title = custom_title = None
    try:
        with open(path) as fh:
            for line in fh:
                try:
                    d = json.loads(line)
                except Exception:
                    continue
                t = d.get("type")
                if t == "custom-title" and d.get("customTitle"):
                    ct = d["customTitle"]
                    # Claude Code auto-generates "(Branch N)" titles from the first
                    # user prompt — when that prompt is a preamble tag, the title
                    # is junk. Discard so we fall back to parent inheritance.
                    if not is_preamble(ct):
                        custom_title = ct
                elif t == "ai-title" and d.get("aiTitle"):
                    title = d["aiTitle"]  # last one wins
                if cwd is None and d.get("cwd"):
                    cwd = d["cwd"]
                if "forkedFrom" in d and parent is None:
                    parent = d["forkedFrom"].get("sessionId")
                    parent_msg = d["forkedFrom"].get("messageUuid")
                if first is None and t == "user":
                    msg = d.get("message", {}) or {}
                    txt = extract_text(msg.get("content"))
                    if txt and not is_preamble(txt):
                        first = txt.strip().replace("\n", " ")
    except Exception:
        return None
    return {
        "sid": sid,
        "cwd": cwd,
        "parent": parent,
        "parent_msg": parent_msg,
        "title": custom_title or title,
        "title_custom": bool(custom_title),
        "first": first or "(no user prompt)",
        "mtime": os.path.getmtime(path),
    }


def load_sessions():
    out = {}
    for f in glob.glob(os.path.expanduser("~/.claude/projects/*/*.jsonl")):
        s = scan_session(f)
        if s:
            out[s["sid"]] = s
    return out


def _color_on():
    # Check fd 1 directly so colors still fire when sys.stdout is redirected
    # to a buffer (watch mode renders into StringIO before flushing).
    try:
        return os.isatty(1)
    except Exception:
        return False


def color(s, c):
    if not _color_on():
        return s
    codes = {"dim": "2", "cyan": "36", "yellow": "33", "green": "32", "bold": "1"}
    return f"\x1b[{codes[c]}m{s}\x1b[0m"


def pid_alive(pid):
    try:
        os.kill(pid, 0)
        return True
    except OSError:
        return False


def running_claude_pid_to_session():
    """pid -> sessionId for live Claude Code processes."""
    out = {}
    d = os.path.expanduser("~/.claude/sessions")
    if not os.path.isdir(d):
        return out
    for f in os.listdir(d):
        if not f.endswith(".json"):
            continue
        try:
            pid = int(f[:-5])
        except ValueError:
            continue
        if not pid_alive(pid):
            continue
        try:
            data = json.load(open(os.path.join(d, f)))
        except Exception:
            continue
        sid = data.get("sessionId")
        if sid:
            out[pid] = sid
    return out


def build_pid_children():
    """ppid -> [child_pid]."""
    children = collections.defaultdict(list)
    try:
        raw = subprocess.check_output(
            ["ps", "-A", "-o", "pid=,ppid="], text=True
        )
    except Exception:
        return children
    for line in raw.splitlines():
        parts = line.split()
        if len(parts) < 2:
            continue
        try:
            pid, ppid = int(parts[0]), int(parts[1])
        except ValueError:
            continue
        children[ppid].append(pid)
    return children


def descendants(root_pid, children):
    stack = [root_pid]
    while stack:
        p = stack.pop()
        yield p
        stack.extend(children.get(p, []))


def tmux_focused_pane_pid(self_pane_id=None):
    """Return pid of the focused pane in our tmux session, or None.

    If the sidebar is itself the focused pane (user clicked into it), we still
    return its pid — caller decides whether to skip based on self_pane_id.
    """
    if not os.environ.get("TMUX"):
        return None
    try:
        ses = subprocess.check_output(
            ["tmux", "display", "-p", "#{session_name}"], text=True
        ).strip()
        raw = subprocess.check_output(
            ["tmux", "list-panes", "-s", "-t", ses, "-F",
             "#{pane_id}|#{?window_active,1,0}|#{?pane_active,1,0}|#{pane_pid}"],
            text=True,
        )
    except Exception:
        return None
    for line in raw.splitlines():
        parts = line.split("|")
        if len(parts) != 4:
            continue
        pane_id, win_active, pane_active, pid = parts
        if win_active == "1" and pane_active == "1":
            if self_pane_id and pane_id == self_pane_id:
                return None  # sidebar is focused — no "other" active pane
            try:
                return int(pid)
            except ValueError:
                return None
    return None


def find_active_claude_session(self_pane_id=None):
    """sessionId of the Claude running in the focused tmux pane, or None."""
    pane_pid = tmux_focused_pane_pid(self_pane_id)
    if not pane_pid:
        return None
    pid_to_sid = running_claude_pid_to_session()
    if not pid_to_sid:
        return None
    children = build_pid_children()
    for pid in descendants(pane_pid, children):
        if pid in pid_to_sid:
            return pid_to_sid[pid]
    return None


def _term_width():
    try:
        import shutil
        return shutil.get_terminal_size((80, 24)).columns
    except Exception:
        return 80


def _truncate(text, width):
    """Truncate plain text to visual width; add … if trimmed."""
    if width < 1:
        return ""
    if len(text) <= width:
        return text
    if width == 1:
        return "…"
    return text[: width - 1] + "…"


def cwd_for_session(sid):
    """Return the cwd recorded for sessionId, by peeking its JSONL header."""
    for f in glob.glob(os.path.expanduser(f"~/.claude/projects/*/{sid}.jsonl")):
        try:
            with open(f) as fh:
                for line in fh:
                    try:
                        d = json.loads(line)
                    except Exception:
                        continue
                    if d.get("cwd"):
                        return d["cwd"]
        except Exception:
            pass
    return None


def render(sessions, roots, include_unbranched, active_sid=None):
    children = collections.defaultdict(list)
    for s in sessions.values():
        children[s["parent"]].append(s["sid"])
    for sids in children.values():
        sids.sort(key=lambda x: sessions[x]["mtime"])

    # Inherit parent's title when child has none (a fork continues the thread).
    for sid, s in sessions.items():
        if s["title"]:
            continue
        cur = s["parent"]
        while cur and cur in sessions:
            if sessions[cur]["title"]:
                s["title"] = sessions[cur]["title"]
                s["inherited"] = True
                break
            cur = sessions[cur]["parent"]

    def has_branch(sid):
        kids = children.get(sid, [])
        return bool(kids) or any(has_branch(k) for k in kids)

    def contains_active(sid):
        if active_sid and sid == active_sid:
            return True
        return any(contains_active(k) for k in children.get(sid, []))

    width = _term_width()

    def walk(sid, prefix="", is_last=True):
        s = sessions[sid]
        connector = "└─ " if is_last else "├─ "
        is_active = active_sid and sid == active_sid
        bullet = "● " if is_active else ""
        date = datetime.fromtimestamp(s["mtime"]).strftime("%m-%d %H:%M")

        head_plain = prefix + connector + bullet
        # Reserve room for a 2-space gap + date on the right.
        avail_for_label = max(1, width - len(head_plain) - 2 - len(date))

        if s["title"]:
            marker = "↑ " if s.get("inherited") else ""
            label_plain = _truncate(marker + s["title"], avail_for_label)
            label_colored = color(label_plain, "green")
        else:
            label_plain = _truncate(s["sid"][:8], avail_for_label)
            label_colored = color(label_plain, "cyan")

        # Pad between label and date so date right-aligns to the terminal edge.
        content_len = len(head_plain) + len(label_plain)
        pad = max(2, width - content_len - len(date))

        line = head_plain + label_colored + (" " * pad) + color(date, "dim")
        if is_active and _color_on():
            line = f"\x1b[1;7m{line}\x1b[0m"  # bold + reverse
        print(line)
        new_prefix = prefix + ("   " if is_last else "│  ")
        kids = children.get(sid, [])
        for i, c in enumerate(kids):
            walk(c, new_prefix, i == len(kids) - 1)

    shown = [r for r in roots if include_unbranched or has_branch(r) or contains_active(r)]
    shown.sort(key=lambda x: sessions[x]["mtime"])
    for i, r in enumerate(shown):
        walk(r, "", i == len(shown) - 1)
    if not shown:
        print(color("(no branched sessions here — try --all-sessions or --all)", "dim"))


def render_for_scope(sessions, path_filter, include_unbranched, all_projects, active_sid):
    """Render either a single project (path_filter) or all branched projects."""
    if all_projects:
        groups = collections.defaultdict(dict)
        for sid, s in sessions.items():
            groups[s["cwd"] or "(unknown)"][sid] = s
        rendered_any = False
        for cwd in sorted(groups):
            subset = groups[cwd]
            children = collections.defaultdict(list)
            for s in subset.values():
                children[s["parent"]].append(s["sid"])
            has_any_branch = any(children.get(sid) for sid in subset)
            has_active = active_sid and active_sid in subset
            if not include_unbranched and not has_any_branch and not has_active:
                continue
            roots = [s["sid"] for s in subset.values() if s["parent"] not in subset]
            print(color(_truncate(f"\n# {cwd}", _term_width() + 1), "bold"))
            render(subset, roots, include_unbranched, active_sid=active_sid)
            rendered_any = True
        if not rendered_any:
            print(color("(no branched sessions anywhere)", "dim"))
        return

    target = os.path.abspath(path_filter)
    subset = {sid: s for sid, s in sessions.items() if s["cwd"] == target}
    if not subset:
        print(color(f"No sessions found for cwd={target}", "yellow"))
        print(color("Try: cctree --all", "dim"))
        return
    roots = [s["sid"] for s in subset.values() if s["parent"] not in subset]
    print(color(_truncate(f"# {target}", _term_width()), "bold"))
    render(subset, roots, include_unbranched, active_sid=active_sid)


def watch_loop(args):
    import io
    import contextlib

    self_pane_id = os.environ.get("TMUX_PANE")
    interval = max(0.3, args.interval)
    last_target = None
    use_alt = _color_on()

    if use_alt:
        # Enter alt screen + hide cursor so the sidebar doesn't pollute scrollback
        # and the caret doesn't flicker on every redraw.
        sys.stdout.write("\x1b[?1049h\x1b[?25l")
        sys.stdout.flush()
    try:
        while True:
            active_sid = find_active_claude_session(self_pane_id)
            if active_sid:
                target = cwd_for_session(active_sid) or (args.path or os.getcwd())
            elif args.path:
                target = args.path
            else:
                target = last_target or os.getcwd()
            last_target = target

            buf = io.StringIO()
            with contextlib.redirect_stdout(buf):
                ts = datetime.now().strftime("%H:%M:%S")
                active_label = (
                    color(active_sid[:8], "green") if active_sid else color("(none)", "dim")
                )
                print(
                    color(f"cctree {__version__}", "bold")
                    + color(f"  {ts}  active: ", "dim")
                    + active_label
                )
                print()
                sessions = load_sessions()
                render_for_scope(
                    sessions,
                    path_filter=target,
                    include_unbranched=args.all_sessions,
                    all_projects=args.all,
                    active_sid=active_sid,
                )

            # In-place redraw: home, then each line clears to end-of-line
            # before its newline; finally clear any leftover rows below.
            # Single write keeps the frame visually atomic → no flicker.
            lines = buf.getvalue().rstrip("\n").split("\n")
            frame = "\x1b[H" + "\n".join(line + "\x1b[K" for line in lines) + "\x1b[J"
            sys.stdout.write(frame)
            sys.stdout.flush()
            time.sleep(interval)
    except KeyboardInterrupt:
        pass
    finally:
        if use_alt:
            sys.stdout.write("\x1b[?25h\x1b[?1049l")
            sys.stdout.flush()


def main():
    ap = argparse.ArgumentParser()
    ap.add_argument("--version", action="version", version=f"cctree {__version__}")
    ap.add_argument("--all", action="store_true", help="show every project dir")
    ap.add_argument("--path", help="filter by cwd (default: $PWD)")
    ap.add_argument(
        "--all-sessions",
        action="store_true",
        help="include sessions that never branched",
    )
    ap.add_argument(
        "--watch",
        action="store_true",
        help="tmux-aware sidebar loop: follow the focused pane and highlight its claude",
    )
    ap.add_argument(
        "--interval",
        type=float,
        default=1.0,
        help="watch-mode refresh seconds (default: 1.0)",
    )
    ap.add_argument(
        "--highlight",
        metavar="SID",
        help="render once and highlight the given session id (prefix match ok)",
    )
    args = ap.parse_args()

    if args.watch:
        watch_loop(args)
        return

    sessions = load_sessions()

    active_sid = None
    if args.highlight:
        # Allow prefix match for convenience.
        matches = [sid for sid in sessions if sid.startswith(args.highlight)]
        active_sid = matches[0] if matches else args.highlight

    render_for_scope(
        sessions,
        path_filter=args.path or os.getcwd(),
        include_unbranched=args.all_sessions,
        all_projects=args.all,
        active_sid=active_sid,
    )


if __name__ == "__main__":
    main()
