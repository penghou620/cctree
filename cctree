#!/usr/bin/env python3
"""
cctree — visualize Claude Code /branch trees.

Usage:
  cctree                      # trees for sessions whose cwd matches $PWD
  cctree --all                # trees across every project dir
  cctree --path <dir>         # trees for a specific working dir
  cctree --all-sessions       # include unbranched (leaf-only) sessions too
  cctree --watch              # tmux-aware sidebar: follow the active pane
  cctree --highlight <sid>    # render once, bold the given sessionId

Branch info comes from `forkedFrom` pointers in ~/.claude/projects/*/*.jsonl.
Active-session detection reads ~/.claude/sessions/<pid>.json and walks
descendants of the focused tmux pane.
"""
import argparse
import collections
import glob
import json
import os
import subprocess
import sys
import time
from datetime import datetime

__version__ = "0.2.0"

# Whether to render 8-char session-id prefixes in the tree / traversal output.
# Off by default; the watch loop toggles this on 'h', and one-shot mode honours
# --show-hash.
_SHOW_HASH = False


def _show_hash():
    return _SHOW_HASH


def _set_show_hash(v):
    global _SHOW_HASH
    _SHOW_HASH = bool(v)


# Whether to render the date/time column (per-row mtime and header clock).
# Defaults to True so one-shot `cctree` output is unchanged; watch_loop flips
# this off at startup and 't' toggles at runtime.
_SHOW_DATE = True


def _show_date():
    return _SHOW_DATE


def _set_show_date(v):
    global _SHOW_DATE
    _SHOW_DATE = bool(v)


# In --watch mode, top-level roots whose most recent activity (across the
# whole subtree) is older than this are auto-collapsed on first render, so
# the sidebar opens on a tight view of recent branches. The user can still
# Tab to expand any of them.
AUTO_COLLAPSE_OLDER_THAN_SECONDS = 24 * 3600


def extract_text(content):
    if isinstance(content, str):
        return content
    if isinstance(content, list):
        for b in content:
            if isinstance(b, dict) and b.get("type") == "text":
                return b.get("text", "")
    return ""


def is_preamble(text: str) -> bool:
    t = text.lstrip()
    if not t:
        return True
    preambles = (
        "<local-command-caveat>",
        "<command-name>",
        "<command-message>",
        "<command-stdout>",
        "<command-args>",
        "<local-command-stdout>",
        "You maintain a persistent memory system",
        "Caveat: The messages below",
    )
    return any(t.startswith(p) for p in preambles)


def _parse_iso_ts(s):
    """ISO 8601 string → POSIX seconds, or None on failure. Accepts the
    trailing-Z UTC form Claude Code writes (`2026-04-13T12:42:43.930Z`)."""
    if not s:
        return None
    try:
        return datetime.fromisoformat(s.replace("Z", "+00:00")).timestamp()
    except Exception:
        return None


def _file_birthtime(path):
    """Best-effort file *creation* time, in POSIX seconds.

    macOS/BSD provide `st_birthtime`; Linux does not, so we fall back to
    mtime. Used as a last-resort sort key when the jsonl has no parseable
    message timestamp."""
    try:
        st = os.stat(path)
        return getattr(st, "st_birthtime", st.st_mtime)
    except OSError:
        return 0.0


def scan_session(path):
    """Return dict of { sessionId, cwd, forkedFrom, title, first, created, mtime } or None.

    `created` is the timestamp of the first message in the conversation —
    a stable creation time that doesn't shift as the session is updated.
    `mtime` is the file's last-modified time (used for the date column and
    auto-collapse heuristics)."""
    sid = os.path.basename(path)[:-6]
    parent = parent_msg = cwd = first = title = custom_title = None
    created = None
    try:
        with open(path) as fh:
            for line in fh:
                try:
                    d = json.loads(line)
                except Exception:
                    continue
                t = d.get("type")
                if t == "custom-title" and d.get("customTitle"):
                    ct = d["customTitle"]
                    # Claude Code auto-generates "(Branch N)" titles from the first
                    # user prompt — when that prompt is a preamble tag, the title
                    # is junk. Discard so we fall back to parent inheritance.
                    if not is_preamble(ct):
                        custom_title = ct
                elif t == "ai-title" and d.get("aiTitle"):
                    title = d["aiTitle"]  # last one wins
                if cwd is None and d.get("cwd"):
                    cwd = d["cwd"]
                if "forkedFrom" in d and parent is None:
                    parent = d["forkedFrom"].get("sessionId")
                    parent_msg = d["forkedFrom"].get("messageUuid")
                if first is None and t == "user":
                    msg = d.get("message", {}) or {}
                    txt = extract_text(msg.get("content"))
                    if txt and not is_preamble(txt):
                        first = txt.strip().replace("\n", " ")
                if created is None:
                    ts = _parse_iso_ts(d.get("timestamp"))
                    if ts is not None:
                        created = ts
    except Exception:
        return None
    return {
        "sid": sid,
        "cwd": cwd,
        "parent": parent,
        "parent_msg": parent_msg,
        "title": custom_title or title,
        "title_custom": bool(custom_title),
        "first": first or "(no user prompt)",
        "created": created if created is not None else _file_birthtime(path),
        "mtime": os.path.getmtime(path),
    }


# Cache of parsed session dicts, keyed by jsonl path. Each entry is
# (mtime_at_scan, session_dict). load_sessions() consults this and only
# re-parses files whose mtime changed since the last call — crucial when
# ~/.claude/projects holds thousands of jsonls (each scan_session reads
# the whole file, so rescanning every tick was the biggest sidebar
# bottleneck).
_SESSIONS_MTIME_CACHE = {}


class _ProjectsWatcher:
    """Optional kqueue-based watcher for ~/.claude/projects/.

    Watches the parent dir and each project subdir for *structural* changes
    (jsonl files added/deleted/renamed, new project subdirs appearing).
    Two payoffs for the watch loop:

      - load_sessions() can fast-path on idle ticks: when no events have
        fired since the last call, the file set is unchanged so we skip
        the scandir over every project dir and just re-stat the cached
        paths for content updates.
      - The watch loop can select() on the kqueue fd alongside stdin,
        so a new session in another pane shows up immediately rather
        than after the next interval tick.

    NOT a watch on file *content* — kqueue on a directory does not fire
    when an existing file is appended to. Mtime updates on existing
    sessions still need interval polling.

    Falls back to a no-op (always-dirty) implementation on platforms
    without select.kqueue (Linux, Windows). Callers should treat the
    `enabled` property as the signal for whether the fast path applies.
    """

    def __init__(self):
        self._enabled = False
        self._dirty = True
        self._dir_fds = {}
        self._kq = None
        self._select = None
        try:
            import select as _select
        except ImportError:
            return
        if not hasattr(_select, "kqueue"):
            return
        try:
            self._kq = _select.kqueue()
        except OSError:
            return
        self._select = _select
        self._refresh_watches()
        # If we couldn't establish a single watch (e.g. ~/.claude/projects
        # doesn't exist yet), give up and let load_sessions fall back to
        # the always-rescan path. The user can restart cctree once claude
        # has created the directory.
        if not self._dir_fds:
            try:
                self._kq.close()
            except OSError:
                pass
            self._kq = None
            return
        self._enabled = True

    @property
    def enabled(self):
        return self._enabled

    @property
    def fd(self):
        """Underlying kqueue fd, or None when disabled. Selectable so the
        watch loop can wake on filesystem events."""
        return self._kq.fileno() if self._kq is not None else None

    def _watch_dir(self, path):
        if path in self._dir_fds:
            return
        try:
            fd = os.open(path, os.O_RDONLY)
        except OSError:
            return
        try:
            ev = self._select.kevent(
                fd,
                filter=self._select.KQ_FILTER_VNODE,
                flags=(self._select.KQ_EV_ADD | self._select.KQ_EV_CLEAR),
                fflags=(self._select.KQ_NOTE_WRITE
                        | self._select.KQ_NOTE_DELETE
                        | self._select.KQ_NOTE_RENAME),
            )
            self._kq.control([ev], 0, 0)
        except OSError:
            os.close(fd)
            return
        self._dir_fds[path] = fd

    def _refresh_watches(self):
        """Add watches for the parent and each subdir we don't already
        cover. Cheap to call repeatedly — _watch_dir short-circuits on
        paths we've already registered."""
        projects = os.path.expanduser("~/.claude/projects")
        if not os.path.isdir(projects):
            return
        self._watch_dir(projects)
        try:
            with os.scandir(projects) as it:
                for entry in it:
                    try:
                        if entry.is_dir(follow_symlinks=False):
                            self._watch_dir(entry.path)
                    except OSError:
                        continue
        except OSError:
            pass

    def consume_events(self):
        """Drain pending kqueue events. Returns True if any fired.
        Sets the internal dirty flag so the next is_dirty() reports
        stale even if no further events arrive."""
        if self._kq is None:
            return False
        try:
            events = self._kq.control(None, 32, 0)
        except OSError:
            return False
        if events:
            self._dirty = True
            # A subdir might have been created — pick it up so its
            # contents trigger events too. Watches on deleted dirs are
            # auto-removed by kqueue when the fd closes; we leak the fd
            # here, which is bounded since project dirs are rarely
            # deleted.
            self._refresh_watches()
            return True
        return False

    def is_dirty(self):
        if not self._enabled:
            return True
        self.consume_events()
        return self._dirty

    def mark_clean(self):
        self._dirty = False

    def close(self):
        for fd in self._dir_fds.values():
            try:
                os.close(fd)
            except OSError:
                pass
        self._dir_fds.clear()
        if self._kq is not None:
            try:
                self._kq.close()
            except OSError:
                pass
            self._kq = None
        self._enabled = False


def load_sessions(watcher=None):
    """Return sid -> session dict for every jsonl under ~/.claude/projects.

    If `watcher` is supplied and reports clean (no fs events since the
    last call), the file set is unchanged so we skip scandir entirely
    and just re-stat the cached paths for mtime updates. Otherwise we
    walk the project dirs to discover new/deleted files.
    """
    fast = watcher is not None and watcher.enabled and not watcher.is_dirty()
    out = {}
    if fast and _SESSIONS_MTIME_CACHE:
        for path, (cached_mt, cached_s) in list(_SESSIONS_MTIME_CACHE.items()):
            try:
                mt = os.path.getmtime(path)
            except OSError:
                # File vanished between events — rare on the fast path
                # since the watcher would have fired. Drop and move on.
                del _SESSIONS_MTIME_CACHE[path]
                continue
            if mt == cached_mt:
                out[cached_s["sid"]] = cached_s
                continue
            s = scan_session(path)
            if s:
                _SESSIONS_MTIME_CACHE[path] = (mt, s)
                out[s["sid"]] = s
        return out

    seen = set()
    projects = os.path.expanduser("~/.claude/projects")
    # scandir nested edges out glob+getmtime: pulls mtime from the dirent
    # without an extra stat per file.
    try:
        with os.scandir(projects) as outer:
            subdirs = [e.path for e in outer if e.is_dir(follow_symlinks=False)]
    except OSError:
        subdirs = []
    for d in subdirs:
        try:
            with os.scandir(d) as inner:
                entries = list(inner)
        except OSError:
            continue
        for f in entries:
            if not f.name.endswith(".jsonl"):
                continue
            try:
                mt = f.stat().st_mtime
            except OSError:
                continue
            path = f.path
            seen.add(path)
            cached = _SESSIONS_MTIME_CACHE.get(path)
            if cached and cached[0] == mt:
                out[cached[1]["sid"]] = cached[1]
                continue
            s = scan_session(path)
            if s:
                _SESSIONS_MTIME_CACHE[path] = (mt, s)
                out[s["sid"]] = s
    for p in list(_SESSIONS_MTIME_CACHE):
        if p not in seen:
            del _SESSIONS_MTIME_CACHE[p]
    if watcher is not None:
        watcher.mark_clean()
    return out


def _color_on():
    # Check fd 1 directly so colors still fire when sys.stdout is redirected
    # to a buffer (watch mode renders into StringIO before flushing).
    try:
        return os.isatty(1)
    except Exception:
        return False


def color(s, c):
    if not _color_on():
        return s
    codes = {"dim": "2", "cyan": "36", "yellow": "33", "green": "32", "bold": "1"}
    return f"\x1b[{codes[c]}m{s}\x1b[0m"


def pid_alive(pid):
    try:
        os.kill(pid, 0)
        return True
    except OSError:
        return False


_UUID_RE = None


def _conversation_sid_from_cmdline(pid):
    """If pid was started via `claude --resume <sid>` / `-r <sid>` /
    `--session-id <sid>`, return that sid. Otherwise None.

    Rationale: `~/.claude/sessions/<pid>.json`'s sessionId is the
    peer-protocol id, which is a fresh UUID on every resume — *not* the
    conversation sid the user cares about. The conversation sid is the
    one the user passed on the command line.
    """
    global _UUID_RE
    if _UUID_RE is None:
        import re
        _UUID_RE = re.compile(
            r"[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}"
        )
    try:
        cmd = subprocess.check_output(
            ["ps", "-o", "command=", "-p", str(pid)],
            text=True, stderr=subprocess.DEVNULL,
        ).strip()
    except Exception:
        return None
    # Tokens like: claude --resume <uuid>, claude -r <uuid>, --session-id <uuid>
    tokens = cmd.split()
    for i, tok in enumerate(tokens):
        if tok in ("--resume", "-r", "--session-id") and i + 1 < len(tokens):
            m = _UUID_RE.fullmatch(tokens[i + 1])
            if m:
                return tokens[i + 1]
        if tok.startswith("--resume=") or tok.startswith("--session-id="):
            val = tok.split("=", 1)[1]
            if _UUID_RE.fullmatch(val):
                return val
    return None


def _jsonl_exists_for_sid(sid):
    """True if ~/.claude/projects/*/<sid>.jsonl exists anywhere."""
    if not sid:
        return False
    return bool(glob.glob(os.path.expanduser(f"~/.claude/projects/*/{sid}.jsonl")))


def running_claude_pid_to_session():
    """pid -> conversation sessionId for live Claude Code processes.

    Resolution order:
      1. Peer sid from ~/.claude/sessions/<pid>.json, if a matching jsonl
         exists on disk. The peer sid updates when the user runs `/resume
         <sid>` inside claude (the way the pane-swap helper switches
         sessions), so this is the source of truth for an already-active
         claude. The jsonl-on-disk check filters out the initial random
         peer UUID that `claude --resume <sid>` assigns before any
         conversation writes happen.
      2. Cmdline `--resume <sid>` / `-r <sid>` / `--session-id <sid>`.
         Catches the case where claude was just started from the shell
         and hasn't written to the target jsonl yet (peer sid is still
         the random startup UUID with no file backing it).
      3. Peer sid as a last resort.
    """
    out = {}
    d = os.path.expanduser("~/.claude/sessions")
    if not os.path.isdir(d):
        return out
    for f in os.listdir(d):
        if not f.endswith(".json"):
            continue
        try:
            pid = int(f[:-5])
        except ValueError:
            continue
        if not pid_alive(pid):
            continue
        try:
            peer_sid = json.load(open(os.path.join(d, f))).get("sessionId")
        except Exception:
            peer_sid = None
        sid = None
        if _jsonl_exists_for_sid(peer_sid):
            sid = peer_sid
        else:
            sid = _conversation_sid_from_cmdline(pid) or peer_sid
        if sid:
            out[pid] = sid
    return out


def build_pid_children():
    """ppid -> [child_pid]."""
    children = collections.defaultdict(list)
    try:
        raw = subprocess.check_output(
            ["ps", "-A", "-o", "pid=,ppid="], text=True
        )
    except Exception:
        return children
    for line in raw.splitlines():
        parts = line.split()
        if len(parts) < 2:
            continue
        try:
            pid, ppid = int(parts[0]), int(parts[1])
        except ValueError:
            continue
        children[ppid].append(pid)
    return children


def descendants(root_pid, children):
    stack = [root_pid]
    while stack:
        p = stack.pop()
        yield p
        stack.extend(children.get(p, []))


def _tmux_focused_pane(self_pane_id=None):
    """Return (pane_id, pid, pane_current_path) of the focused pane in our tmux session.

    If the focused pane IS the sidebar itself, returns (None, None, None). Else
    returns the focused pane's id, pid, and shell-level cwd so the sidebar
    can fall back to "where the user is" when no claude is active yet.
    """
    if not os.environ.get("TMUX"):
        return None, None, None
    try:
        ses = subprocess.check_output(
            ["tmux", "display", "-p", "#{session_name}"], text=True
        ).strip()
        raw = subprocess.check_output(
            ["tmux", "list-panes", "-s", "-t", ses, "-F",
             "#{pane_id}|#{?window_active,1,0}|#{?pane_active,1,0}|"
             "#{pane_pid}|#{pane_current_path}"],
            text=True,
        )
    except Exception:
        return None, None, None
    for line in raw.splitlines():
        parts = line.split("|", 4)
        if len(parts) != 5:
            continue
        pane_id, win_active, pane_active, pid, path = parts
        if win_active == "1" and pane_active == "1":
            if self_pane_id and pane_id == self_pane_id:
                return None, None, None
            try:
                return pane_id, int(pid), (path or None)
            except ValueError:
                return pane_id, None, (path or None)
    return None, None, None


def tmux_focused_pane_pid(self_pane_id=None):
    """Backward-compatible wrapper — returns just the pid."""
    _, pid, _ = _tmux_focused_pane(self_pane_id)
    return pid


def tmux_focused_pane_cwd(self_pane_id=None):
    """cwd of the focused (non-sidebar) pane via tmux, or None."""
    _, _, path = _tmux_focused_pane(self_pane_id)
    return path


def find_active_claude_session(self_pane_id=None):
    """sessionId of the Claude running in the focused tmux pane, or None."""
    pane_pid = tmux_focused_pane_pid(self_pane_id)
    if not pane_pid:
        return None
    pid_to_sid = running_claude_pid_to_session()
    if not pid_to_sid:
        return None
    children = build_pid_children()
    for pid in descendants(pane_pid, children):
        if pid in pid_to_sid:
            return pid_to_sid[pid]
    return None


def _parent_pid(pid):
    try:
        out = subprocess.check_output(
            ["ps", "-o", "ppid=", "-p", str(pid)], text=True, stderr=subprocess.DEVNULL
        )
        return int(out.strip())
    except Exception:
        return None


def detect_self_session():
    """Walk up from our own PID looking for an ancestor that has a live
    ~/.claude/sessions/<pid>.json file. Returns sessionId or None."""
    pid_to_sid = running_claude_pid_to_session()
    if not pid_to_sid:
        return None
    cur = os.getpid()
    seen = set()
    while cur and cur > 1 and cur not in seen:
        seen.add(cur)
        if cur in pid_to_sid:
            return pid_to_sid[cur]
        cur = _parent_pid(cur)
    return None


def _fmt_row(sid, sessions):
    s = sessions.get(sid)
    if not s:
        return f"{sid[:8]}  (not on disk)" if _show_hash() else "(not on disk)"
    date = datetime.fromtimestamp(s["mtime"]).strftime("%m-%d %H:%M")
    if s["title"]:
        title_colored = color(s["title"], "green")
    else:
        title_colored = color(sid[:8], "cyan")
    if _show_hash() and s["title"]:
        return f"{color(sid[:8], 'cyan')}  {color(date, 'dim')}  {title_colored}"
    return f"{color(date, 'dim')}  {title_colored}"


def _spawn_resumed(target_sid, label):
    """Open a new tmux pane running `claude --resume target_sid`. Returns True
    on success (in tmux) or False if not in tmux / spawn failed."""
    if not os.environ.get("TMUX"):
        print()
        print(color("(--jump needs tmux to open a new pane)", "dim"))
        return False
    try:
        subprocess.run(
            ["tmux", "split-window", "-h", f"claude --resume {target_sid}"],
            check=True,
        )
    except Exception as e:
        print(color(f"\nfailed to open tmux pane: {e}", "yellow"))
        return False
    print()
    print(color(f"→ opened {label} ({target_sid[:8]}) in a new tmux pane", "green"))
    return True


def _pane_swap_loop(pane, target_sid):
    """Background helper: wait for the pane to stop changing (i.e. claude
    finished its response), then switch the session in place by typing
    `/resume <sid>` into claude's input box.

    `/resume` is a built-in Claude Code slash command that swaps the
    active session without restarting the process — the same claude PID
    keeps running, the conversation sid changes, and the jsonl it writes
    to changes with it. No C-c C-c, no shell round-trip, no cwd dance.

    Logs to ~/.claude/cctree-pane-swap.log so mis-fires are diagnosable.
    """
    log_path = os.path.expanduser("~/.claude/cctree-pane-swap.log")

    def log(msg):
        try:
            with open(log_path, "a") as f:
                f.write(
                    f"{datetime.now().isoformat()} pane={pane} "
                    f"target={target_sid[:8]} {msg}\n"
                )
        except Exception:
            pass

    log("start")
    prev = None
    stable = 0
    deadline = time.time() + 60
    hit_stable = False
    while time.time() < deadline:
        try:
            cur = subprocess.check_output(
                ["tmux", "capture-pane", "-p", "-t", pane], text=True
            )
        except Exception as e:
            log(f"capture failed: {e}")
            return
        if cur == prev:
            stable += 1
            if stable >= 6:  # 3s of unchanged pane → claude is idle
                hit_stable = True
                break
        else:
            stable = 0
        prev = cur
        time.sleep(0.5)
    if not hit_stable:
        log("deadline reached without stability; swapping anyway")
    else:
        log(f"pane stable after {stable} captures")

    cmd = f"/resume {target_sid}"
    log(f"send: {cmd}")
    subprocess.run(["tmux", "send-keys", "-t", pane, cmd, "Enter"])
    log("done")


def _spawn_pane_swap_helper(pane_id, target_sid):
    """Spawn the detached pane-swap helper that types `/resume <sid>` into
    the given pane once claude is idle. Returns True on success, False if
    Popen itself failed."""
    try:
        subprocess.Popen(
            [sys.executable, os.path.abspath(__file__),
             "--pane-swap", "--pane", pane_id, "--target", target_sid],
            start_new_session=True,  # survive parent claude's exit
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )
        return True
    except Exception:
        return False


def _jump_inplace(target_sid, label):
    """Schedule an in-place pane swap to target_sid via a detached helper."""
    pane = os.environ.get("TMUX_PANE")
    if not pane:
        print()
        print(color("(--jump-inplace needs tmux)", "dim"))
        return False
    if not _spawn_pane_swap_helper(pane, target_sid):
        print(color("\nfailed to spawn helper", "yellow"))
        return False
    # Include the wall-clock time so a *replayed* /up (from session history
    # re-rendered after a resume) is visually distinguishable from a fresh
    # invocation: on replay the timestamp is old, and no helper is actually
    # running. Claude Code does not re-execute Bash tool calls on resume,
    # so the replayed line is text-only — no swap fires. Timestamping makes
    # that unambiguous instead of looking like the swap hung.
    ts = datetime.now().strftime("%H:%M:%S")
    print()
    print(color(
        f"→ [{ts}] pane swap queued → {label} ({target_sid[:8]})",
        "green",
    ))
    return True


def cmd_traverse(direction, sid_arg, jump=False, jump_inplace=False):
    """direction: 'up' | 'down' | 'self'"""
    sessions = load_sessions()

    start = sid_arg or detect_self_session()
    if not start:
        print(
            "cctree: could not detect current session. Pass --sid <prefix> "
            "(are you running this from inside a claude session?)",
            file=sys.stderr,
        )
        sys.exit(2)

    # prefix match against loaded sessions
    full = start if start in sessions else next(
        (s for s in sessions if s.startswith(start)), start
    )

    if direction == "self":
        print(full)
        return

    cur_row = _fmt_row(full, sessions)
    print(f"Current:  {cur_row}")

    s = sessions.get(full)
    if direction == "up":
        parent = s["parent"] if s else None
        if not parent:
            print(color("  (no parent — this is a root session)", "dim"))
            return
        print(f"Parent:   {_fmt_row(parent, sessions)}")
        if jump_inplace:
            if _jump_inplace(parent, "parent"):
                return
        if jump:
            if _spawn_resumed(parent, "parent"):
                return
        print()
        print("To resume parent:")
        print(f"  claude --resume {parent}")
        return

    # down
    kids = sorted(
        (c for c in sessions.values() if c["parent"] == full),
        key=lambda c: c["created"],
    )
    if not kids:
        print(color("  (no children — this is a leaf session)", "dim"))
        return
    if (jump or jump_inplace) and len(kids) == 1:
        kid = kids[0]
        print(f"Child:    {_fmt_row(kid['sid'], sessions)}")
        if jump_inplace and _jump_inplace(kid["sid"], "child"):
            return
        if jump and _spawn_resumed(kid["sid"], "child"):
            return
        print()
        print("To resume child:")
        print(f"  claude --resume {kid['sid']}")
        return
    print(f"Children ({len(kids)}):")
    for i, c in enumerate(kids, 1):
        print(f"  [{i}] {_fmt_row(c['sid'], sessions)}")
    print()
    if len(kids) == 1:
        print("To resume child:")
        print(f"  claude --resume {kids[0]['sid']}")
    else:
        print("To resume a child:")
        print("  claude --resume <sid from the list above>")


def _term_width():
    try:
        import shutil
        return shutil.get_terminal_size((80, 24)).columns
    except Exception:
        return 80


def _truncate(text, width):
    """Truncate plain text to visual width; add … if trimmed."""
    if width < 1:
        return ""
    if len(text) <= width:
        return text
    if width == 1:
        return "…"
    return text[: width - 1] + "…"


# Keybinding rows for the watch-mode help overlay. Two columns: the key on
# the left (cyan), description on the right.
_HELP_BINDINGS = [
    ("j / ↓",   "move selection down"),
    ("k / ↑",   "move selection up"),
    ("g / G",   "first / last visible row"),
    ("Tab",     "collapse / expand node"),
    ("↵",       "swap focused pane to selected"),
    ("/",       "filter (Esc to clear)"),
    ("r",       "rename selected session"),
    ("h",       "toggle session id hash column"),
    ("t",       "toggle date/time column"),
    ("?",       "toggle this help"),
    ("q / Esc", "quit"),
]


def _render_help_overlay():
    """Print the help overlay. Called instead of the tree when the user has
    `?` toggled on. Caller has already printed the header + a blank line."""
    print(color("keybindings", "bold"))
    key_w = max(len(k) for k, _ in _HELP_BINDINGS)
    width = _term_width()
    for k, desc in _HELP_BINDINGS:
        line = color(k.ljust(key_w), "cyan") + "  " + desc
        # Truncation is per-column to avoid clipping the key when the desc
        # is long; the desc gets truncated instead.
        budget = width - (key_w + 2)
        if len(desc) > budget:
            line = color(k.ljust(key_w), "cyan") + "  " + _truncate(desc, budget)
        print(line)


def cwd_for_session(sid):
    """Return the cwd recorded for sessionId, by peeking its JSONL header."""
    for f in glob.glob(os.path.expanduser(f"~/.claude/projects/*/{sid}.jsonl")):
        try:
            with open(f) as fh:
                for line in fh:
                    try:
                        d = json.loads(line)
                    except Exception:
                        continue
                    if d.get("cwd"):
                        return d["cwd"]
        except Exception:
            pass
    return None


def _write_custom_title(sid, title):
    """Append a `custom-title` line to sid's jsonl. scan_session reads the
    last one wins, so this overrides any prior title.

    Returns True on success, False if the jsonl wasn't found or the write
    failed."""
    paths = glob.glob(os.path.expanduser(f"~/.claude/projects/*/{sid}.jsonl"))
    if not paths:
        return False
    line = json.dumps(
        {"type": "custom-title", "customTitle": title, "sessionId": sid},
        separators=(",", ":"),
    ) + "\n"
    try:
        with open(paths[0], "a") as fh:
            fh.write(line)
    except OSError:
        return False
    return True


def render(sessions, roots, include_unbranched, active_sid=None,
           selected_sid=None, collapsed_sids=frozenset(), visible_out=None,
           live_sids=frozenset(), filter_query=""):
    """Render the tree. In interactive mode (visible_out is not None) adds a
    cursor column + fold indicators, and hides descendants of any sid in
    collapsed_sids. selected_sid (if set) is drawn with a cursor prefix.

    live_sids: sessions backed by a live claude process. Roots that contain a
    live sid are kept visible even when they have no branches yet — so two
    claudes running in sibling panes both appear before either one forks.

    filter_query: case-insensitive substring; rows whose title/sid match are
    highlighted, ancestors of matches are kept normal, everything else is
    dimmed. Collapsed nodes whose subtree contains a match auto-expand."""
    children = collections.defaultdict(list)
    for s in sessions.values():
        children[s["parent"]].append(s["sid"])
    # Sort by *creation* time so the tree order is stable — sorting by mtime
    # caused branches to reshuffle whenever the user touched an old session.
    for sids in children.values():
        sids.sort(key=lambda x: sessions[x]["created"])

    # Inherit parent's title when child has none (a fork continues the thread).
    for sid, s in sessions.items():
        if s["title"]:
            continue
        cur = s["parent"]
        while cur and cur in sessions:
            if sessions[cur]["title"]:
                s["title"] = sessions[cur]["title"]
                s["inherited"] = True
                break
            cur = sessions[cur]["parent"]

    def has_branch(sid):
        kids = children.get(sid, [])
        return bool(kids) or any(has_branch(k) for k in kids)

    def contains_active(sid):
        if active_sid and sid == active_sid:
            return True
        if sid in live_sids:
            return True
        return any(contains_active(k) for k in children.get(sid, []))

    fq = (filter_query or "").lower()

    def row_match(sid):
        s = sessions[sid]
        hay = ((s.get("title") or "") + " " + sid[:8]).lower()
        return fq in hay if fq else False

    _subtree_match_cache = {}

    def subtree_match(sid):
        if sid in _subtree_match_cache:
            return _subtree_match_cache[sid]
        m = row_match(sid) or any(subtree_match(k) for k in children.get(sid, []))
        _subtree_match_cache[sid] = m
        return m

    _subtree_size_cache = {}

    def subtree_size(sid):
        """Total number of descendants under sid (excludes sid itself)."""
        if sid in _subtree_size_cache:
            return _subtree_size_cache[sid]
        n = 0
        for k in children.get(sid, []):
            n += 1 + subtree_size(k)
        _subtree_size_cache[sid] = n
        return n

    interactive = visible_out is not None
    width = _term_width()

    def walk(sid, prefix="", is_last=True):
        s = sessions[sid]
        kids = children.get(sid, [])
        is_collapsed = interactive and sid in collapsed_sids and bool(kids)
        # Auto-expand collapsed nodes whose subtree contains a filter match,
        # otherwise the user types `/foo` and sees nothing.
        if fq and is_collapsed and subtree_match(sid):
            is_collapsed = False
        connector = "└─ " if is_last else "├─ "
        is_active = active_sid and sid == active_sid
        is_selected = interactive and selected_sid == sid
        bullet = "● " if is_active else ""
        show_date = _show_date()
        date = datetime.fromtimestamp(s["mtime"]).strftime("%m-%d %H:%M") if show_date else ""
        # Width reserved on the right for "  MM-DD HH:MM"; zero when hidden.
        date_reserve = (2 + len(date)) if show_date else 0

        # Interactive mode reserves a 2-char cursor column at the far left and
        # a 2-char fold-indicator slot between the tree connector and bullet.
        if interactive:
            cursor = "▶ " if is_selected else "  "
            if kids:
                fold = "▸ " if is_collapsed else "▾ "
            else:
                fold = "  "
            head_plain = cursor + prefix + connector + fold + bullet
            cursor_colored = color(cursor, "cyan") if is_selected else cursor
            fold_colored = color(fold, "dim") if kids else fold
            head_colored = cursor_colored + prefix + connector + fold_colored + bullet
        else:
            head_plain = prefix + connector + bullet
            head_colored = head_plain

        # Collapsed nodes get a dim "(N)" suffix showing how many descendants
        # are hidden — appended to the label rather than the fold column to
        # avoid the label horizontally shifting on every toggle.
        if interactive and is_collapsed and kids:
            count_suffix = f" ({subtree_size(sid)})"
        else:
            count_suffix = ""

        avail_for_label = max(1, width - len(head_plain) - date_reserve - len(count_suffix))

        sid_short = s["sid"][:8]
        show_hash = _show_hash()
        if s["title"]:
            marker = "↑ " if s.get("inherited") else ""
            # Reserve room for " (xxxxxxxx)" after the title; drop the suffix
            # if the terminal is too narrow to fit anything useful, or if the
            # user has hidden the hash.
            suffix_len = len(sid_short) + 3  # " (" + sid + ")"
            if show_hash and avail_for_label - suffix_len >= 4:
                title_plain = _truncate(marker + s["title"], avail_for_label - suffix_len)
                label_plain = f"{title_plain} ({sid_short})"
                label_colored = color(title_plain, "green") + color(f" ({sid_short})", "dim")
            else:
                label_plain = _truncate(marker + s["title"], avail_for_label)
                label_colored = color(label_plain, "green")
        else:
            label_plain = _truncate(sid_short, avail_for_label)
            label_colored = color(label_plain, "cyan")

        # Filter overrides: yellow for direct matches, dim for non-ancestors.
        # Ancestors-of-matches keep their normal coloring so the path is
        # readable.
        if fq:
            if row_match(sid):
                label_colored = color(label_plain, "yellow")
            elif not subtree_match(sid):
                label_colored = color(label_plain, "dim")

        if count_suffix:
            label_plain += count_suffix
            label_colored += color(count_suffix, "dim")

        if show_date:
            # Pad between label and date so date right-aligns to the terminal edge.
            content_len = len(head_plain) + len(label_plain)
            pad = max(2, width - content_len - len(date))
            line = head_colored + label_colored + (" " * pad) + color(date, "dim")
        else:
            line = head_colored + label_colored
        if is_active and _color_on():
            line = f"\x1b[1;7m{line}\x1b[0m"  # bold + reverse
        print(line)
        if interactive:
            visible_out.append(sid)
        if is_collapsed:
            return
        new_prefix = prefix + ("   " if is_last else "│  ")
        for i, c in enumerate(kids):
            walk(c, new_prefix, i == len(kids) - 1)

    shown = [r for r in roots if include_unbranched or has_branch(r) or contains_active(r)]
    shown.sort(key=lambda x: sessions[x]["created"])
    for i, r in enumerate(shown):
        walk(r, "", i == len(shown) - 1)
    if not shown:
        print(color("(no branched sessions here — try --all-sessions or --all)", "dim"))


def render_for_scope(sessions, path_filter, include_unbranched, all_projects,
                     active_sid, selected_sid=None, collapsed_sids=frozenset(),
                     visible_out=None, live_sids=frozenset(), filter_query=""):
    """Render either a single project (path_filter) or all branched projects."""
    if all_projects:
        groups = collections.defaultdict(dict)
        for sid, s in sessions.items():
            groups[s["cwd"] or "(unknown)"][sid] = s
        rendered_any = False
        for cwd in sorted(groups):
            subset = groups[cwd]
            children = collections.defaultdict(list)
            for s in subset.values():
                children[s["parent"]].append(s["sid"])
            has_any_branch = any(children.get(sid) for sid in subset)
            has_active = active_sid and active_sid in subset
            has_live = any(sid in subset for sid in live_sids)
            if (not include_unbranched and not has_any_branch
                    and not has_active and not has_live):
                continue
            roots = [s["sid"] for s in subset.values() if s["parent"] not in subset]
            print(color(_truncate(f"\n# {cwd}", _term_width() + 1), "bold"))
            render(subset, roots, include_unbranched, active_sid=active_sid,
                   selected_sid=selected_sid, collapsed_sids=collapsed_sids,
                   visible_out=visible_out, live_sids=live_sids,
                   filter_query=filter_query)
            rendered_any = True
        if not rendered_any:
            print(color("(no branched sessions anywhere)", "dim"))
        return

    target = os.path.abspath(path_filter)
    subset = {sid: s for sid, s in sessions.items() if s["cwd"] == target}
    if not subset:
        print(color(f"No sessions found for cwd={target}", "yellow"))
        print(color("Try: cctree --all", "dim"))
        return
    roots = [s["sid"] for s in subset.values() if s["parent"] not in subset]
    print(color(_truncate(f"# {target}", _term_width()), "bold"))
    render(subset, roots, include_unbranched, active_sid=active_sid,
           selected_sid=selected_sid, collapsed_sids=collapsed_sids,
           visible_out=visible_out, live_sids=live_sids,
           filter_query=filter_query)


def _auto_collapse_old_root_sids(sessions, active_sid,
                                 age_seconds=AUTO_COLLAPSE_OLDER_THAN_SECONDS):
    """Return sids of top-level roots whose entire subtree is idle for longer
    than age_seconds. Any tree that contains active_sid is kept expanded so
    the user's current work is never hidden."""
    if not sessions:
        return set()
    children = collections.defaultdict(list)
    for s in sessions.values():
        children[s["parent"]].append(s["sid"])
    roots = [
        s["sid"] for s in sessions.values()
        if s["parent"] is None or s["parent"] not in sessions
    ]
    threshold = time.time() - age_seconds

    def contains_active(sid):
        if active_sid and sid == active_sid:
            return True
        return any(contains_active(k) for k in children.get(sid, []))

    def subtree_max_mtime(sid):
        m = sessions[sid]["mtime"]
        for k in children.get(sid, []):
            m = max(m, subtree_max_mtime(k))
        return m

    return {
        r for r in roots
        if subtree_max_mtime(r) < threshold and not contains_active(r)
    }


def _read_key():
    """Read one key from stdin (which must already be in cbreak mode).

    Returns a symbolic name for special keys (UP/DOWN/TAB/ENTER/ESC/BACKSPACE)
    or the literal character otherwise. Handles multi-byte ESC sequences for
    arrow keys."""
    import select
    ch = sys.stdin.read(1)
    if ch == "\x1b":
        r, _, _ = select.select([sys.stdin], [], [], 0.01)
        if r:
            seq = sys.stdin.read(2)
            return {"[A": "UP", "[B": "DOWN", "[C": "RIGHT", "[D": "LEFT"}.get(seq, "ESC")
        return "ESC"
    if ch == "\t":
        return "TAB"
    if ch in ("\r", "\n"):
        return "ENTER"
    if ch in ("\x7f", "\b"):
        return "BACKSPACE"
    return ch


def watch_loop(args):
    import io
    import contextlib
    import select

    self_pane_id = os.environ.get("TMUX_PANE")
    interval = max(0.3, args.interval)
    use_alt = _color_on()

    # Watch mode hides the date/time column by default; 't' toggles it back on.
    _set_show_date(False)

    # kqueue watcher on ~/.claude/projects — lets load_sessions() skip the
    # full scandir on idle ticks and lets the inner select() wake on new/
    # deleted sessions without waiting for the next interval. No-op on
    # platforms without kqueue (Linux/Windows fall back to polling).
    fs_watcher = _ProjectsWatcher()

    # Put stdin into cbreak mode so we can poll j/k/tab/h without line-buffering.
    # Falls back gracefully if stdin is not a TTY (e.g. redirected for tests).
    old_tty = None
    interactive = False
    try:
        if sys.stdin.isatty():
            import termios
            import tty
            old_tty = termios.tcgetattr(sys.stdin)
            tty.setcbreak(sys.stdin.fileno())
            interactive = True
    except Exception:
        old_tty = None
        interactive = False

    collapsed_sids = set()
    selected_sid = None
    visible = []  # sids currently on screen, in display order — rebuilt each frame
    auto_collapsed_done = False  # one-shot: seed collapsed_sids with old roots

    # Refreshed state: updated on interval ticks + on cheap pane-change probes,
    # but never on keypress — so j/k/Tab just re-render from cached values and
    # stay instant.
    sessions_cache = {}
    active_sid = None
    live_sids = frozenset()
    target = None
    last_target = None
    last_pane_pid = None
    # Most recent non-sidebar focused pane id. Enter-to-swap targets this so
    # the user can move focus into the sidebar to navigate (j/k/Tab) and still
    # have the swap land on the pane they came from.
    last_focused_pane_id = None
    # (msg, expiry_ts) for the transient feedback line shown under the header
    # after Enter is pressed. None = no message.
    swap_status = None
    # `/` filter state. filter_mode=True while user is typing the query;
    # filter_query is the (lowercased downstream) substring matched against
    # row titles + sid prefix. Empty query means "no filter active".
    filter_query = ""
    filter_mode = False
    # `r` rename state. rename_mode=True while user is editing the title;
    # rename_value holds the current input. Pre-filled with the existing
    # title on entry so the user can tweak rather than retype.
    rename_mode = False
    rename_value = ""
    # `?` toggles a full keybindings overlay so the inline legend can stay
    # tight on a 47-col sidebar.
    help_visible = False

    if use_alt:
        # Enter alt screen + hide cursor so the sidebar doesn't pollute scrollback
        # and the caret doesn't flicker on every redraw.
        sys.stdout.write("\x1b[?1049h\x1b[?25l")
        sys.stdout.flush()

    def refresh_state():
        nonlocal sessions_cache, active_sid, live_sids, target, last_target
        nonlocal auto_collapsed_done, last_pane_pid, last_focused_pane_id

        sessions_cache = load_sessions(fs_watcher)

        pane_id, pane_pid, pane_cwd = _tmux_focused_pane(self_pane_id)
        last_pane_pid = pane_pid
        # Keep the last non-sidebar pane id so Enter still works after the
        # user has moved focus into the sidebar to navigate.
        if pane_id is not None:
            last_focused_pane_id = pane_id
        pid_to_sid = running_claude_pid_to_session()
        live_sids = frozenset(pid_to_sid.values())
        if pane_pid and pid_to_sid:
            children = build_pid_children()
            active_sid = next(
                (pid_to_sid[p] for p in descendants(pane_pid, children)
                 if p in pid_to_sid),
                None,
            )
        else:
            active_sid = None

        if active_sid:
            cached = sessions_cache.get(active_sid)
            active_cwd = cached["cwd"] if cached else None
            target = active_cwd or pane_cwd or args.path or os.getcwd()
        elif args.path:
            target = args.path
        else:
            target = pane_cwd or last_target or os.getcwd()
        last_target = target

        # Auto-collapse idle top-level trees on the very first refresh so the
        # sidebar opens focused on recent work. User-driven Tab toggles after
        # this point persist (we don't re-seed on subsequent reloads).
        if interactive and not auto_collapsed_done and sessions_cache:
            collapsed_sids.update(
                _auto_collapse_old_root_sids(sessions_cache, active_sid)
            )
            auto_collapsed_done = True

    def render_frame():
        nonlocal visible, selected_sid

        if selected_sid is None and active_sid:
            selected_sid = active_sid

        visible = []
        buf = io.StringIO()
        with contextlib.redirect_stdout(buf):
            if active_sid:
                active_label = (
                    color(active_sid[:8], "green")
                    if _show_hash()
                    else color("●", "green")
                )
            else:
                active_label = color("(none)", "dim")
            header = color(f"cctree {__version__}", "bold")
            if _show_date():
                ts = datetime.now().strftime("%H:%M:%S")
                header += color(f"  {ts}  active: ", "dim") + active_label
            else:
                header += color("  active: ", "dim") + active_label
            if interactive:
                header += color("  ·  ?: help  q: quit", "dim")
            print(header)
            if swap_status and time.time() < swap_status[1]:
                swap_color = "green" if swap_status[0].startswith("→") else "yellow"
                print(color(swap_status[0], swap_color))
            if rename_mode:
                # While editing — show prompt with trailing cursor.
                print(
                    color("rename: ", "cyan")
                    + color(rename_value, "yellow")
                    + color("_", "dim")
                )
            elif filter_mode:
                # While typing — show the prompt with a trailing cursor.
                print(color(f"/{filter_query}", "yellow") + color("_", "dim"))
            elif filter_query:
                # Filter committed — keep it visible and remind how to clear.
                print(
                    color(f"filter: /{filter_query}", "yellow")
                    + color("   (Esc: clear)", "dim")
                )
            print()
            if help_visible:
                # Overlay replaces the tree until any key is pressed. Keeping
                # the tree out makes wide bindings readable on narrow sidebars.
                _render_help_overlay()
                # `visible` is intentionally left empty — j/k navigation is
                # disabled until the overlay closes, which is what we want.
            else:
                render_for_scope(
                    sessions_cache,
                    path_filter=target,
                    include_unbranched=args.all_sessions,
                    all_projects=args.all,
                    active_sid=active_sid,
                    selected_sid=selected_sid if interactive else None,
                    collapsed_sids=collapsed_sids,
                    visible_out=visible if interactive else None,
                    live_sids=live_sids,
                    filter_query=filter_query,
                )

        # If the selected sid vanished (e.g. its ancestor was collapsed, or it
        # no longer exists on disk), snap back to something on screen.
        if interactive and visible and selected_sid not in visible:
            selected_sid = visible[0]

        # In-place redraw: home, then each line clears to end-of-line before
        # its newline; finally clear any leftover rows below. Single write
        # keeps the frame visually atomic → no flicker.
        lines = buf.getvalue().rstrip("\n").split("\n")
        frame = "\x1b[H" + "\n".join(line + "\x1b[K" for line in lines) + "\x1b[J"
        sys.stdout.write(frame)
        sys.stdout.flush()

    def pane_changed():
        """Cheap probe: did the focused tmux pane's pid change since the last
        refresh? One tmux call, no ps/glob. Lets us react to pane switches
        well before the next interval tick without paying for a full state
        refresh on every loop iteration."""
        _, pid, _ = _tmux_focused_pane(self_pane_id)
        return pid != last_pane_pid

    def handle_key(key):
        """Return True if the frame needs an immediate redraw, False if no-op,
        or the string 'quit' to break the outer loop."""
        nonlocal selected_sid, collapsed_sids, swap_status
        nonlocal filter_query, filter_mode
        nonlocal rename_mode, rename_value
        nonlocal help_visible

        # Help overlay swallows the next keypress: any key dismisses it. We
        # don't fall through to the action — the user pressed a key to *close*
        # help, not to fire something they couldn't see.
        if help_visible:
            help_visible = False
            return True

        # While editing a rename, route every key through the input handler.
        if rename_mode:
            if key == "ENTER":
                if not selected_sid:
                    rename_mode = False
                    return True
                title = rename_value.strip()
                if not title:
                    swap_status = ("rename cancelled (empty title)", time.time() + 2)
                    rename_mode = False
                    return True
                if _write_custom_title(selected_sid, title):
                    # Drop the cached entry so the next refresh re-parses and
                    # picks up the new title without waiting for mtime drift.
                    for p, (_, sd) in list(_SESSIONS_MTIME_CACHE.items()):
                        if sd["sid"] == selected_sid:
                            del _SESSIONS_MTIME_CACHE[p]
                            break
                    swap_status = (f"→ renamed: {title}", time.time() + 2)
                else:
                    swap_status = (
                        "rename failed (jsonl not found)",
                        time.time() + 3,
                    )
                rename_mode = False
                return True
            if key == "ESC":
                rename_mode = False
                return True
            if key == "BACKSPACE":
                rename_value = rename_value[:-1]
                return True
            if isinstance(key, str) and len(key) == 1 and key >= " " and key != "\x7f":
                rename_value += key
                return True
            return False

        # While composing a `/` query, route every key through the input
        # handler — including 'q' / 'h' / 't' (they're literal chars, not
        # toggles, in this mode).
        if filter_mode:
            if key == "ENTER":
                filter_mode = False
                return True
            if key == "ESC":
                filter_mode = False
                filter_query = ""
                return True
            if key == "BACKSPACE":
                if filter_query:
                    filter_query = filter_query[:-1]
                    return True
                # Empty query + Backspace → bail out of filter mode entirely.
                filter_mode = False
                return True
            if isinstance(key, str) and len(key) == 1 and key >= " " and key != "\x7f":
                filter_query += key
                return True
            return False

        if key == "q":
            return "quit"
        if key == "ESC":
            # Esc clears an active filter before quitting, so it acts like a
            # gentle "back out" rather than always killing the sidebar.
            if filter_query:
                filter_query = ""
                return True
            return "quit"
        if key == "?":
            help_visible = True
            return True
        if key == "/":
            filter_mode = True
            filter_query = ""
            return True
        if key in ("r", "R"):
            if selected_sid:
                s = sessions_cache.get(selected_sid) or {}
                # Pre-fill with the current title so tweaks are easy. Inherited
                # titles aren't really *this* session's title, so start blank
                # in that case rather than committing the parent's text.
                if s.get("title") and not s.get("inherited"):
                    rename_value = s["title"]
                else:
                    rename_value = ""
                rename_mode = True
                return True
            return False
        if key in ("h", "H"):
            _set_show_hash(not _show_hash())
            return True
        if key in ("t", "T"):
            _set_show_date(not _show_date())
            return True
        if not visible:
            return False
        try:
            idx = visible.index(selected_sid) if selected_sid in visible else 0
        except ValueError:
            idx = 0
        if key in ("j", "DOWN"):
            selected_sid = visible[min(idx + 1, len(visible) - 1)]
            return True
        if key in ("k", "UP"):
            selected_sid = visible[max(idx - 1, 0)]
            return True
        if key == "g":
            selected_sid = visible[0]
            return True
        if key == "G":
            selected_sid = visible[-1]
            return True
        if key == "TAB":
            if selected_sid in collapsed_sids:
                collapsed_sids.discard(selected_sid)
            else:
                collapsed_sids.add(selected_sid)
            return True
        if key == "ENTER":
            if not selected_sid:
                return False
            if selected_sid == active_sid:
                swap_status = ("already on this session", time.time() + 2)
                return True
            if not last_focused_pane_id:
                swap_status = (
                    "no target pane (focus a non-sidebar pane first)",
                    time.time() + 3,
                )
                return True
            if _spawn_pane_swap_helper(last_focused_pane_id, selected_sid):
                s = sessions_cache.get(selected_sid) or {}
                label = s.get("title") or selected_sid[:8]
                swap_status = (
                    f"→ swap queued: {label} ({selected_sid[:8]})",
                    time.time() + 4,
                )
            else:
                swap_status = ("failed to spawn swap helper", time.time() + 3)
            return True
        return False

    try:
        while True:
            refresh_state()
            render_frame()
            # Between interval ticks, serve keypress-driven redraws from cached
            # state (fast path). Also poll for tmux pane changes every ~200ms so
            # the sidebar reacts to "user switched panes" without waiting a full
            # interval for the next refresh. The kqueue fd (when available) is
            # added to the select set so new/deleted sessions surface
            # immediately rather than after the next tick.
            deadline = time.time() + interval
            last_probe = time.time()
            while time.time() < deadline:
                fds = []
                if interactive:
                    fds.append(sys.stdin)
                watcher_fd = fs_watcher.fd
                if watcher_fd is not None:
                    fds.append(watcher_fd)
                remaining = max(0.02, min(0.1, deadline - time.time()))
                if fds:
                    r, _, _ = select.select(fds, [], [], remaining)
                else:
                    time.sleep(remaining)
                    r = []
                if interactive and sys.stdin in r:
                    result = handle_key(_read_key())
                    if result == "quit":
                        return
                    if result:
                        render_frame()
                if watcher_fd is not None and watcher_fd in r:
                    # Drain events and bail to the outer loop so the new
                    # state lands on screen before any keystroke. The
                    # consume_events() call also marks the cache stale
                    # so the upcoming load_sessions() does a full rescan.
                    fs_watcher.consume_events()
                    break
                now = time.time()
                if now - last_probe >= 0.2:
                    last_probe = now
                    if pane_changed():
                        break  # fall through to a full refresh+render
    except KeyboardInterrupt:
        pass
    finally:
        fs_watcher.close()
        if use_alt:
            sys.stdout.write("\x1b[?25h\x1b[?1049l")
            sys.stdout.flush()
        if old_tty is not None:
            import termios
            try:
                termios.tcsetattr(sys.stdin, termios.TCSADRAIN, old_tty)
            except Exception:
                pass


def main():
    ap = argparse.ArgumentParser()
    ap.add_argument("--version", action="version", version=f"cctree {__version__}")
    ap.add_argument("--all", action="store_true", help="show every project dir")
    ap.add_argument("--path", help="filter by cwd (default: $PWD)")
    ap.add_argument(
        "--all-sessions",
        action="store_true",
        help="include sessions that never branched",
    )
    ap.add_argument(
        "--watch",
        action="store_true",
        help="tmux-aware sidebar loop: follow the focused pane and highlight its claude",
    )
    ap.add_argument(
        "--interval",
        type=float,
        default=1.0,
        help="watch-mode refresh seconds (default: 1.0)",
    )
    ap.add_argument(
        "--highlight",
        metavar="SID",
        help="render once and highlight the given session id (prefix match ok)",
    )
    ap.add_argument(
        "--show-hash",
        dest="show_hash",
        action="store_true",
        help="show the 8-char session id next to each row (hidden by default; "
             "toggle at runtime in --watch with the 'h' key)",
    )
    ap.add_argument("--self", dest="show_self", action="store_true",
                    help="print the sessionId of the enclosing claude process")
    ap.add_argument("--up", action="store_true",
                    help="show the parent of the current (or --sid) session")
    ap.add_argument("--down", action="store_true",
                    help="show the children of the current (or --sid) session")
    ap.add_argument("--sid", metavar="SID",
                    help="override which session to traverse from (prefix ok)")
    ap.add_argument("--jump", action="store_true",
                    help="open the resumed session in a new tmux pane (with --up/--down)")
    ap.add_argument("--jump-inplace", dest="jump_inplace", action="store_true",
                    help="swap the current tmux pane's claude session in place "
                         "(waits for current response to finish, then types "
                         "/resume <sid> — same process, no restart)")
    # Internal: invoked by --jump-inplace as a detached helper.
    ap.add_argument("--pane-swap", dest="pane_swap", action="store_true",
                    help=argparse.SUPPRESS)
    ap.add_argument("--pane", help=argparse.SUPPRESS)
    ap.add_argument("--target", help=argparse.SUPPRESS)
    args = ap.parse_args()

    if args.show_hash:
        _set_show_hash(True)

    if args.pane_swap:
        if not args.pane or not args.target:
            sys.exit("--pane-swap requires --pane and --target")
        _pane_swap_loop(args.pane, args.target)
        return
    if args.show_self:
        cmd_traverse("self", args.sid)
        return
    if args.up:
        cmd_traverse("up", args.sid, jump=args.jump, jump_inplace=args.jump_inplace)
        return
    if args.down:
        cmd_traverse("down", args.sid, jump=args.jump, jump_inplace=args.jump_inplace)
        return
    if args.watch:
        watch_loop(args)
        return

    sessions = load_sessions()

    active_sid = None
    if args.highlight:
        # Allow prefix match for convenience.
        matches = [sid for sid in sessions if sid.startswith(args.highlight)]
        active_sid = matches[0] if matches else args.highlight

    live_sids = frozenset(running_claude_pid_to_session().values())

    render_for_scope(
        sessions,
        path_filter=args.path or os.getcwd(),
        include_unbranched=args.all_sessions,
        all_projects=args.all,
        active_sid=active_sid,
        live_sids=live_sids,
    )


if __name__ == "__main__":
    main()
